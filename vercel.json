{
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push && next build",
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    {
      "path": "/api/cron/generate-blog",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/distribute-content",
      "schedule": "30 9 * * *"
    }
  ]
}
