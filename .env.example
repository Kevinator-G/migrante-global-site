# Copia este archivo como .env.local y rellena los valores reales
# NUNCA subas .env.local al repositorio

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera_uno_con: openssl rand -base64 32

# Base de datos (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require&channel_binding=require"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI
OPENAI_API_KEY=sk-proj-...

# URL pública del API (en local: http://localhost:3000, en producción: https://tu-dominio.vercel.app)
NEXT_PUBLIC_API_URL=http://localhost:3000
