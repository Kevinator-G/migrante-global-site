# Copia este archivo como .env.local y rellena los valores reales
# NUNCA subas .env.local al repositorio

# NextAuth
NEXTAUTH_URL=http://localhost:3000
# En Vercel se establece automáticamente como VERCEL_URL, pero NextAuth necesita la URL exacta:
# NEXTAUTH_URL=https://tu-dominio.vercel.app
NEXTAUTH_SECRET=genera_uno_con: openssl rand -base64 32

# Base de datos Neon PostgreSQL
# Para entornos serverless (Vercel) usa la URL con pooler pgBouncer:
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
# URL directa para migraciones (prisma migrate deploy):
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI
OPENAI_API_KEY=sk-proj-...

# URL pública del API
# En local:
NEXT_PUBLIC_API_URL=http://localhost:3000
# En Vercel (producción):
# NEXT_PUBLIC_API_URL=https://tu-dominio.vercel.app

# ─── Solo para CI/CD con GitHub Actions ───────────────────────────────────────
# Añade estos como Secrets en GitHub (Settings → Secrets → Actions):
# VERCEL_TOKEN       → vercel.com/account/tokens
# VERCEL_ORG_ID      → vercel.com/[team]/settings → Team ID
# VERCEL_PROJECT_ID  → vercel.com/[team]/[proyecto]/settings → Project ID
